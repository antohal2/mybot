# Telegram Bot Token (get from @BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# Admin Telegram IDs (comma-separated, get your ID from @userinfobot)
ADMIN_IDS=123456789,987654321

# 3x-ui Panel settings
XUI_HOST=http://YOUR_SERVER_IP:2053
XUI_USERNAME=admin
XUI_PASSWORD=admin

# Inbound ID in 3x-ui panel (usually 1 for the first inbound)
XUI_INBOUND_ID=1

# Default subscription settings
DEFAULT_TRAFFIC_GB=50
DEFAULT_DAYS=30

# Database file path
DB_PATH=bot.db

# Payment providers (optional, comment out if not using)
# Telegram Stars (built-in)
USE_TELEGRAM_STARS=true

# YooKassa (https://yookassa.ru)
YOOKASSA_SHOP_ID=your_shop_id
YOOKASSA_SECRET_KEY=your_secret_key

# CryptoPay (https://t.me/CryptoBot)
CRYPTOPAY_TOKEN=your_cryptopay_token

# Tariff prices (in rubles for YooKassa, in XTR for Telegram Stars)
PRICE_TRIAL=0
PRICE_1_MONTH=300
PRICE_3_MONTHS=800
PRICE_6_MONTHS=1400
